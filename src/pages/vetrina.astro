---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import { withBaseUrl } from '../lib/withBaseUrl';
import { getSiteSettings, getGalleryItems } from '../lib/localContent';

const [settings, galleryItems] = await Promise.all([
  getSiteSettings(),
  getGalleryItems(),
]);

const siteTitle = settings?.title ?? '707';
const logoSrc = settings?.heroImage ?? null;
const homeHref = withBaseUrl('/');
const vetrinaPageLabelRaw = typeof settings?.vetrinaPageLabel === 'string' ? settings.vetrinaPageLabel.trim() : '';
const vetrinaPageLabel = vetrinaPageLabelRaw.length > 0 ? vetrinaPageLabelRaw : 'VETRINA';
const homeLinkLabelRaw = typeof settings?.homeLinkLabel === 'string' ? settings.homeLinkLabel.trim() : '';
const homeLinkLabel = homeLinkLabelRaw.length > 0 ? homeLinkLabelRaw : 'Home';
const galleryEmptyTextRaw = typeof settings?.galleryEmptyText === 'string' ? settings.galleryEmptyText.trim() : '';
const galleryEmptyText = galleryEmptyTextRaw.length > 0 ? galleryEmptyTextRaw : 'Nessun file trovato.';
const pageTitle = `${siteTitle} — ${vetrinaPageLabel}`;
const vetrinaFooter = settings?.vetrinaFooter ?? null;
---

<Layout title={pageTitle} bodyClass="page-vetrina">
  <header class="vetrina-header">
    <div class="vetrina-header__bar">
      <div class="vetrina-header__side vetrina-header__side--left">
        <a href={homeHref} class="back"><span class="back-arr" aria-hidden="true">←</span> {homeLinkLabel}</a>
      </div>
      {logoSrc && <img class="logo" src={logoSrc} alt="" width="120" />}
      <div class="vetrina-header__side vetrina-header__side--right" aria-hidden="true"></div>
    </div>
    <div class="title-box">
      <div class="title">{pageTitle}</div>
    </div>
  </header>

  <GalleryGrid items={galleryItems} emptyText={galleryEmptyText} />

  {vetrinaFooter && <footer class="vetrina-footer">{vetrinaFooter}</footer>}
</Layout>

<style is:global>
  html:has(body.page-vetrina) {
    background-color: #070400;
    min-height: 100%;
  }

  body.page-vetrina {
    background:
      radial-gradient(circle at 12% 8%, rgba(255, 204, 88, 0.26), transparent 30%),
      radial-gradient(circle at 82% 22%, rgba(255, 141, 22, 0.22), transparent 38%),
      radial-gradient(circle at 48% 92%, rgba(115, 59, 6, 0.28), transparent 44%),
      linear-gradient(180deg, #070400 0%, #170d03 46%, #080300 100%);
    color: #ffecc1;
    text-align: center;
    font-family: 'Inter', 'Trebuchet MS', 'Segoe UI', sans-serif;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  body.page-vetrina::before {
    content: "";
    position: fixed;
    inset: 0;
    background:
      linear-gradient(transparent 0%, rgba(0, 0, 0, 0.2) 48%, transparent 100%),
      repeating-linear-gradient(
        0deg,
        rgba(255, 213, 115, 0.04) 0px,
        rgba(255, 213, 115, 0.04) 1px,
        transparent 2px,
        transparent 22px
      );
    pointer-events: none;
    z-index: 0;
    animation: screenDrift 18s linear infinite;
  }

  body.page-vetrina > * {
    position: relative;
    z-index: 1;
  }

  @keyframes screenDrift {
    0% { transform: translateY(0); }
    100% { transform: translateY(18px); }
  }

  body.page-vetrina .vetrina-header {
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
    padding: 8px 14px 10px;
    background: rgba(12, 6, 0, 0.84);
    border-bottom: 1px solid rgba(255, 220, 132, 0.24);
    box-shadow:
      0 10px 28px rgba(0, 0, 0, 0.36),
      0 0 18px rgba(255, 184, 44, 0.12);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  body.page-vetrina .vetrina-header__bar {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    min-height: 44px;
    line-height: 0;
  }

  body.page-vetrina .vetrina-header__side {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  body.page-vetrina .vetrina-header__side--left {
    justify-content: flex-start;
  }

  body.page-vetrina .vetrina-header__side--right {
    justify-content: flex-end;
  }

  body.page-vetrina .back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    gap: 8px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1;
    color: #180a00;
    min-height: 40px;
    padding: 0 20px;
    border-radius: 999px;
    border: 1px solid rgba(255, 238, 181, 0.78);
    background: linear-gradient(135deg, #fff0a5, #c88112);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.35),
      0 0 18px rgba(255, 190, 45, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.72);
    transition:
      color 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  body.page-vetrina .back .back-arr {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.1em;
    height: 1em;
    margin: 0;
    color: #6b3100;
    font-weight: 700;
    font-size: 16px;
    line-height: 1;
  }

  body.page-vetrina .back:hover {
    color: #120700;
    background: linear-gradient(135deg, #fff8cc, #f0b23b);
    border-color: rgba(255, 250, 207, 0.95);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.35),
      0 4px 22px rgba(255, 190, 45, 0.3);
  }

  body.page-vetrina .vetrina-header .logo {
    flex: 0 0 auto;
    height: 40px;
    width: auto;
    border-radius: 6px;
    box-shadow:
      0 0 10px rgba(255, 224, 126, 0.52),
      0 0 22px rgba(255, 157, 35, 0.34);
    align-self: center;
  }

  body.page-vetrina .title-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    color: #ffe7a5;
    min-width: 0;
    padding-top: 0;
    border-top: none;
  }

  body.page-vetrina .title-box .title {
    font-size: clamp(13px, 2.8vw, 16px);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffd86b;
    text-shadow:
      0 0 8px rgba(255, 216, 75, 0.48),
      0 0 18px rgba(255, 139, 22, 0.32);
  }

  body.page-vetrina .vetrina-footer {
    margin-top: 40px;
    padding: 24px;
    font-size: 13px;
    opacity: 0.76;
    color: #d5b976;
  }
</style>
