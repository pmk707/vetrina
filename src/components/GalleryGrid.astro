---
import GalleryItem from './GalleryItem.astro'
import type { GalleryItemData } from '../lib/localContent'

interface Props {
  items: GalleryItemData[]
  emptyText: string
}
const { items, emptyText } = Astro.props
---

<div class="wrap">
  {items.length === 0 ? (
    <p class="empty">{emptyText}</p>
  ) : (
    <div class="feed">
      {items.map((item) => (
        <GalleryItem title={item.title} mediaUrl={item.mediaUrl} mp4Url={item.mp4Url} />
      ))}
    </div>
  )}
</div>

<style>
  .wrap {
    max-width: min(1200px, calc(100% - 24px));
    margin: 22px auto 0 auto;
    padding: 0 16px;
  }

  .feed {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (min-width: 720px) {
    .feed {
      gap: 18px;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    }
  }

  .empty {
    padding: 32px 0;
    font-size: 13px;
    color: #d5b976;
  }
</style>
